---
# ZestStream Brand Voice — local settings
# Copy this file to settings.local.md (same directory) and fill in values.
# Ported from anthropics/knowledge-work-plugins, adapted for ZestStream.

brand: zeststream

enforcement:
  strictness: strict          # strict | balanced | flexible
  always-explain: true        # include "Voice decisions" note with every rewrite
  auto-reject-ungrounded: true   # unmatched claims blocked (never relax for zeststream)
  auto-reject-banned: true    # banned-word hit blocks (never relax for zeststream)

scorer:
  ship_threshold: 95
  regen_threshold: 85
  any_dim_floor: 9
  primary_model: "claude-sonnet-4-6"
  bulk_model: "grok-4-1-fast-reasoning"
  temperature: 0

grounding:
  require_source_in: ["capabilities-ground-truth.yaml"]
  stale_days_warning: 30      # warn, not block
  vague_quantifier_reject: true

open_questions:
  share_with_team: false

drift:
  cron_probe_wave_a: true
  drift_block_threshold: 3    # ≥3/10 ticks in window → write .ecosystem/STOP
---

# Context overrides (optional)

## Canon override
