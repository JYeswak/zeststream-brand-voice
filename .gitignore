# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Python (for future scorer)
__pycache__/
*.pyc
.venv/
venv/

# Node (for future Qdrant adapter)
node_modules/

# Local settings — never commit brand-specific secrets
skills/brand-voice/brands/*/settings.local.md
skills/brand-voice/brands/*/.env
!skills/brand-voice/brands/*/settings.local.md.example

# Per-brand private scratch (raw scrapes, interviews)
skills/brand-voice/brands/*/_raw/
skills/brand-voice/brands/*/_interview/

# Scorecard and trauma logs (brand-specific, may contain pre-rewrite drafts)
skills/brand-voice/brands/*/trauma.jsonl
skills/brand-voice/brands/*/scorecard-log.jsonl
skills/brand-voice/brands/*/calibration.md

# Quarantined exemplars (deleted after review)
skills/brand-voice/brands/*/exemplars/_quarantined/

# Private open-questions (brand-specific — example brands may keep it public)
skills/brand-voice/brands/zeststream/OPEN_QUESTIONS.md

# === @zeststream/security-hygiene canonical .env guard ===
# Canonical @zeststream/security-hygiene gitignore env block — v0.0.1
#
# Append this block to a repo's .gitignore to enforce the
# "never-commit-real-secrets; only-template-files-commit" policy.
#
# Hardened across 3 ratifications:
#   - terratitle b15qk (commit e33d1dc) — initial fold
#   - josh-ops htv0d (commit 6bd3423)   — second fold
#   - alpsinsurance (pre-existing)      — independent convergence
#
# Behavior:
#   - .env / .env.* matches all environment variants (.env.prod,
#     .env.staging, .env.dev, .env.local, future variants)
#   - !.env.example / !.env.local.example bang-overrides re-allow
#     template files at any depth
#   - **/.env.example / **/.env.local.example explicit-depth variants
#     cover sub-directory templates (frontend/.env.example etc.)

# Environment — never commit real secrets; only .env.example variants
.env
.env.*
!.env.example
!.env.local.example
!**/.env.example
!**/.env.local.example
